# ==============================================================================
# .env.example — 复制为 .env 后按需修改
#   cp .env.example .env
# ==============================================================================

# ---------- 数据库 ----------
# 本地开发（相对路径，sqlite 文件在项目根目录）
DB_URL=sqlite+aiosqlite:///./sqlite.db
# Docker 部署（绝对路径，指向容器内挂载卷）
# DB_URL=sqlite+aiosqlite:////app/data/sqlite.db
# 若使用 PostgreSQL
# DB_URL=postgresql+asyncpg://user:password@host:5432/dbname

# 是否打印 SQL（调试时开）
DB_ECHO=false

# ---------- Redis ----------
# 本地开发
REDIS_URL=redis://localhost:6379/0
# Docker 部署（服务名 redis）
# REDIS_URL=redis://redis:6379/0

# ---------- AI (Anthropic 兼容接口) ----------
AI_BASE_URL=https://api.anthropic.com
AI_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=claude-sonnet-4-5
# 单次回复最大 token 数（默认 8192）
AI_MAX_TOKENS=64000

# ---------- 上下文压缩 ----------
# 超过多少条消息触发摘要
SUMMARY_MAX_MESSAGES=21
# 超过多少 token 触发摘要
SUMMARY_MAX_TOKENS=64000

# ---------- EQ 优化 ----------
# 优化 EQ 单次最大 token 数
OPTIMIZE_EQ_MAX_TOKENS=8192

# ---------- 工具调用 ----------
# 等待前端回传工具结果的超时（秒）
WAIT_FOR_FRONTEND_RESULT_TIMEOUT=30
# Redis 缓存工具结果的超时（秒）
CACHE_TOOL_RESULT_TIMEOUT=60

# ==============================================================================
# 以下仅 docker-compose 使用，不会被 pydantic-settings 读取
# ==============================================================================

# ---------- Compose ----------
# 容器宿主机端口（对应 app 的 8000）
APP_PORT=8000

# ---------- Docker 日志轮转 ----------
# 单个 container log 文件大小上限
LOG_MAX_SIZE=10m
# 保留多少个轮转后的旧日志
LOG_MAX_FILE=5

# ==============================================================================
# 以下仅部署脚本 (scripts/deploy.sh) 使用
# ==============================================================================

# 部署目标分支（非此分支的 commit 不会触发自动部署）
# DEPLOY_BRANCH=main
# 远端 SSH 目标
# DEPLOY_SSH_TARGET=ubuntu@ec2-18-184-205-87.eu-central-1.compute.amazonaws.com
# 本地私钥路径
# DEPLOY_SSH_KEY=~/.ssh/id_ed25519
# 远端部署目录
# DEPLOY_REMOTE_DIR=/data/project/luxsin-tool
